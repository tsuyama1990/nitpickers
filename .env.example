# Tier A: Secret Tier
# These variables contain sensitive authentication credentials.
# They MUST NOT be committed to version control.
# Copy this file to .env to use these settings locally.

# Core API Keys
JULES_API_KEY=your_jules_key
E2B_API_KEY=your_e2b_key
OPENROUTER_API_KEY=your_openrouter_key

# Observability Configuration (Required for Phase 0 Verification)
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key
LANGCHAIN_PROJECT=your_langsmith_project_name

# -------------------------------------------------------------------
# Tier B: Tuning Tier (Version-controlled configuration)
# The following variables are managed in docker-compose.yml
# and should NOT be placed in this local .env file unless you are
# running the system outside of Docker. They are listed here for reference.
#
# NITPICK_AUDITOR_MODEL=openai:gpt-4o
# NITPICK_REVIEWER__SMART_MODEL=openai:gpt-4o
# NITPICK_NUM_AUDITORS=3
# NITPICK_REVIEWS_PER_AUDITOR=2
# NITPICK_MAX_ITERATIONS=3
